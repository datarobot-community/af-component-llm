"""
Choose this option when you have an OpenAI-compatible endpoint
(e.g. Ollama, vLLM, a custom inference server). Set OPENAI_API_BASE to your endpoint's
base URL, OPENAI_API_TOKEN to your API token, and LLM_DEFAULT_MODEL to the model name
your endpoint expects.
"""

import os

from datarobot_pulumi_utils.pulumi import export
import pulumi
import pulumi_datarobot as datarobot

from .lib{{ llm_app_name|lower|replace('-','_')}} import (
    validate_feature_flags,
    verify_llm,
)

__all__ = [
    "app_runtime_parameters",
    "custom_model_runtime_parameters",
    "default_model",
    "{{llm_app_name}}_application_name",
]

REQUIRED_FEATURE_FLAGS = {
    "ENABLE_MLOPS": True,
    "ENABLE_CUSTOM_INFERENCE_MODEL": True,
    "ENABLE_PUBLIC_NETWORK_ACCESS_FOR_ALL_CUSTOM_MODELS": True,
    "ENABLE_MLOPS_TEXT_GENERATION_TARGET_TYPE": True,
}

{{llm_app_name}}_application_name: str = "{{llm_app_name}}"

# Cross-map OPENAI_API_TOKEN -> OPENAI_API_KEY for LiteLLM compatibility
if not os.environ.get("OPENAI_API_KEY"):
    os.environ["OPENAI_API_KEY"] = os.environ.get("OPENAI_API_TOKEN", "")

_raw_model: str = os.environ.get(
    "LLM_DEFAULT_MODEL",
    os.environ.get("{{llm_app_name|upper}}_DEFAULT_MODEL", "gpt-4o"),
)
# Ensure the openai/ prefix is present for LiteLLM calls
default_model: str = (
    _raw_model if _raw_model.startswith("openai/") else f"openai/{_raw_model}"
)

# Verify everything is configured properly for this configuration option.
validate_feature_flags(REQUIRED_FEATURE_FLAGS)

# Verify your OpenAI-compatible endpoint is reachable.
# LiteLLM picks up OPENAI_API_BASE and OPENAI_API_KEY from the environment automatically.
# See https://docs.litellm.ai/docs/providers/openai_compatible for details.
verify_llm(default_model)

openai_api_token_credential = datarobot.ApiTokenCredential(
    resource_name=f"{pulumi.get_project()} OPENAI_API_TOKEN [{{llm_app_name}}]",
    api_token=os.environ.get("OPENAI_API_TOKEN", ""),
)

app_runtime_parameters = [
    datarobot.ApplicationSourceRuntimeParameterValueArgs(
        key="OPENAI_API_BASE",
        type="string",
        value=os.environ.get("OPENAI_API_BASE", ""),
    ),
    datarobot.ApplicationSourceRuntimeParameterValueArgs(
        key="OPENAI_API_TOKEN",
        type="credential",
        value=openai_api_token_credential.id,
    ),
    datarobot.ApplicationSourceRuntimeParameterValueArgs(
        key="{{llm_app_name|upper}}_DEFAULT_MODEL",
        type="string",
        value=default_model,
    ),
]
custom_model_runtime_parameters = [
    datarobot.CustomModelRuntimeParameterValueArgs(
        key="OPENAI_API_BASE",
        type="string",
        value=os.environ.get("OPENAI_API_BASE", ""),
    ),
    datarobot.CustomModelRuntimeParameterValueArgs(
        key="OPENAI_API_TOKEN",
        type="credential",
        value=openai_api_token_credential.id,
    ),
    datarobot.CustomModelRuntimeParameterValueArgs(
        key="{{llm_app_name|upper}}_DEFAULT_MODEL",
        type="string",
        value=default_model,
    ),
]
export("OPENAI_API_BASE", os.environ.get("OPENAI_API_BASE", ""))
export("{{llm_app_name|upper}}_DEFAULT_MODEL", default_model)
